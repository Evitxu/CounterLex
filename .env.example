# LLM provider: "ollama" (local, free) or "openai" (OpenAI-compatible API, e.g. Groq)
LLM_PROVIDER=ollama

# --- Ollama (local) — https://ollama.com  (then: ollama pull llama3.1) ---
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.1
ALLOW_EXTRACTOR_FALLBACK=true      # keyword fallback when the LLM is unreachable

# --- OpenAI-compatible (used when LLM_PROVIDER=openai; defaults target Groq) ---
# Get a free key at https://console.groq.com  (no credit card)
LLM_API_KEY=
LLM_BASE_URL=https://api.groq.com/openai/v1
LLM_MODEL=llama-3.1-8b-instant

# Storage
SQLITE_PATH=counterlex.db

# Synthetic corpus
DEFAULT_CORPUS_SIZE=400
SYNTHETIC_SEED=7

# Retrieval
TOP_K_PRECEDENTS=6

# CORS + demo bootstrap
FRONTEND_ORIGIN=http://localhost:3000
BOOTSTRAP_ON_STARTUP=true
