# Ollama (local, free LLM) — https://ollama.com  (then: ollama pull llama3.1)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.1
ALLOW_EXTRACTOR_FALLBACK=true      # keyword fallback when Ollama is unreachable

# Storage
SQLITE_PATH=counterlex.db

# Synthetic corpus
DEFAULT_CORPUS_SIZE=400
SYNTHETIC_SEED=7

# Retrieval
TOP_K_PRECEDENTS=6

# CORS + demo bootstrap
FRONTEND_ORIGIN=http://localhost:3000
BOOTSTRAP_ON_STARTUP=true
